	<queryString>
		<![CDATA[select *
from liquidacion_demo.reporte_composito_de_lotes rcl
inner join liquidacion_demo.composito_de_lotes_detalle cld on rcl.id = cld.reporte_composito_de_lotes_id
left join liquidacion_demo.empresa emp on rcl.empresa_id = emp.id
where rcl.id=$P{reporteCompositoDeLotesId}]]>
	</queryString>
