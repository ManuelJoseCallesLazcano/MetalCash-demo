	<parameter name="realPath" class="java.lang.String">
		<defaultValueExpression><![CDATA["/home/manuel/IdeaProjects/ALLOMIN/sistemaLiquidacionesAllomin/web-app/reports/images/"]]></defaultValueExpression>
	</parameter>
	<parameter name="anticipoId" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select ant.id,
ant.numero_comprobante,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
cli.ci,
cli.nombre as nombre_cliente,
ant.primer_anticipo,
ant.fecha_primer_anticipo,
ant.segundo_anticipo,
ant.fecha_segundo_anticipo,
ant.tercer_anticipo,
ant.fecha_tercer_anticipo,
ant.total_anticipos,
ant.literal_total_anticipos,
ant.descripcion,
ant.observaciones,
usu.nombre as nombre_usuario,
det.id as detalle_anticipo_id,
det.lote,
det.fecha_de_recepcion,
det.nombre_empresa,
det.nombre_cliente,
det.peso_bruto,
det.tipo_de_material,
dep.nombre_deposito,
dep.codigo_deposito,
dep.direccion as direccion_deposito
from liquidacion_demo.anticipo ant
inner join liquidacion_demo.anticipo_detalle det on det.anticipo_id=ant.id
inner join liquidacion_demo.empresa emp on emp.id=ant.empresa_id
inner join liquidacion_demo.cliente cli on cli.id=ant.cliente_id
inner join liquidacion_demo.sec_user usu on usu.id=ant.usuario_id
left join liquidacion_demo.deposito dep on dep.id=ant.deposito_id
where ant.id=$P{anticipoId}]]>
	</queryString>
