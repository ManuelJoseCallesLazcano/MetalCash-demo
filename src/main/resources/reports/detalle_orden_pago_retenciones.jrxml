	<parameter name="pagoRetencionesId" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT pag.id,
pag.numero_comprobante,
pag.fecha_de_pago,
pag.periodo,
pag.quincena,
pag.total_pagable,
ret.id,
ret.lote,
ret.kilos_netos_secos,
ret.valor_oficial_neto,
ret.descripcion,
ret.cantidad_descuento,
ret.unidad_de_descuento,
ret.asignacion_del_descuento,
ret.monto,
dep.nombre_deposito,
dep.codigo_deposito,
dep.direccion as direccion_deposito
FROM liquidacion_demo.retencion_pagada ret
inner join liquidacion_demo.pago_de_retenciones pag on ret.pago_de_retenciones_id=pag.id
left join liquidacion_demo.deposito dep on dep.id=pag.deposito_id
where pag.id=$P{pagoRetencionesId}]]>
	</queryString>
