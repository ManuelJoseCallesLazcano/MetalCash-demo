	<parameter name="realPath" class="java.lang.String">
		<defaultValueExpression><![CDATA["/home/manuel/IdeaProjects/SMART/liquidaciones/demo-liquidaciones/src/main/resources/reports/images/"]]></defaultValueExpression>
	</parameter>
	<parameter name="id" class="java.lang.String">
		<defaultValueExpression><![CDATA[8]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select pag.id,
pag.numero_comprobante,
pag.fecha_de_pago,
pag.gestion_minera,
pag.ci,
pag.nombre_cobrador,
pag.solicitante,
pag.empresa_id,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
pag.automovil_id,
aut.placa,
aut.modelo,
aut.color,
pag.descripcion,
pag.peso_bruto,
pag.precio_tonelada,
pag.total,
pag.total_anticipos,
pag.total_pagable,
pag.total_pagable_literal,
pag.observaciones,
pag.anulado,
usu.nombre as usuario,
dep.nombre_deposito,
dep.codigo_deposito,
dep.direccion as direccion_deposito
from liquidacion_demo.pago_transporte pag
inner join liquidacion_demo.sec_user usu on usu.id=pag.usuario_id
left join liquidacion_demo.empresa emp on emp.id=pag.empresa_id
left join liquidacion_demo.automovil aut on aut.id=pag.automovil_id
left join liquidacion_demo.deposito dep on dep.id=pag.deposito_id
where pag.id=$P{id}]]>
	</queryString>
