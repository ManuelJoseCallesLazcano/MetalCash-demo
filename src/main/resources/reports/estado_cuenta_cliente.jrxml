		<defaultValueExpression><![CDATA["01/05/2026 AL 31/07/2026"]]></defaultValueExpression>
	</parameter>
	<parameter name="RANGO_FECHAS" class="java.lang.String">
		<defaultValueExpression><![CDATA["AND edc.fecha >= '2026-05-01 00:00:00' AND edc.fecha <= '2026-08-28 23:00:00' "]]></defaultValueExpression>
	</parameter>
	<parameter name="realPath" class="java.lang.String">
