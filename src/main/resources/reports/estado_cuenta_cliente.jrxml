	</parameter>
	<queryString>
		<![CDATA[SELECT edc.id,
cli.ci,
cli.nombre as nombre_cliente,
emp.tipo_de_empresa,
emp.nombre_de_empresa as nombre_empresa,
edc.fecha,
edc.detalle,
edc.debe,
edc.haber,
edc.saldo
FROM liquidacion_demo.estado_de_cuenta edc
inner join liquidacion_demo.cliente cli on cli.id = edc.cliente_id
inner join liquidacion_demo.empresa emp on emp.id = cli.empresa_id
WHERE edc.cliente_id = $P{id}
$P!{RANGO_FECHAS}
ORDER BY edc.id]]>
	</queryString>
