	</parameter>
	<queryString>
		<![CDATA[SELECT
      ac.id                        AS cuota_id,
      ac.numero_comprobante        AS numero_comprobante,
      ac.gestion_minera            AS gestion_minera,
      YEAR(ac.gestion_minera)      AS gestion_anio,
      ac.fecha                     AS fecha_emision,
      ac.monto                     AS monto,
      ac.anulado                   AS anulado,
      ac.fecha_anulacion           AS fecha_anulacion,
      a.id                         AS anticipo_id,
      a.tipo_de_mineral            AS tipo_de_mineral,
      a.lotes                      AS lotes,
      a.descripcion                AS descripcion,
      a.observaciones              AS observaciones,
      a.total_anticipos            AS total_anticipos,
      a.literal_total_anticipos    AS literal_total_anticipos,
      a.total_pagado               AS total_pagado,
      a.total_por_pagar            AS total_por_pagar,
      a.nombre_cliente             AS nombre_cliente,
      a.nombre_empresa             AS nombre_empresa,
      cl.ci                        AS cliente_ci,
      cl.nombre                    AS cliente_nombre,
      cl.cuadrilla                 AS cliente_cuadrilla,
      cl.telefono                  AS cliente_telefono,
      cl.celular                   AS cliente_celular,
      em.tipo_de_empresa         AS tipo_de_empresa,
      em.nombre_de_empresa         AS empresa_nombre,
      em.codigo_empresa            AS empresa_codigo,
      em.nit                       AS empresa_nit,
      em.nim                       AS empresa_nim,
      dep.codigo_deposito          AS deposito_codigo,
      dep.nombre_deposito          AS deposito_nombre,
      dep.direccion                AS deposito_direccion,
      u.nombre                     AS usuario_nombre,
      u.username                   AS usuario_username
  FROM liquidacion_demo.anticipo_cuota ac
      INNER JOIN liquidacion_demo.anticipo  a   ON a.id  = ac.anticipo_id
      LEFT  JOIN liquidacion_demo.cliente   cl  ON cl.id = a.cliente_id
      LEFT  JOIN liquidacion_demo.empresa   em  ON em.id = a.empresa_id
      LEFT  JOIN liquidacion_demo.deposito  dep ON dep.id = ac.deposito_id
      LEFT  JOIN liquidacion_demo.sec_user  u   ON u.id  = ac.usuario_id
  WHERE ac.id = $P{id}]]>
	</queryString>
