	<parameter name="realPath" class="java.lang.String">
		<defaultValueExpression><![CDATA["/home/manuel/IdeaProjects/ALLOMIN/sistemaLiquidacionesAllomin/web-app/reports/images/"]]></defaultValueExpression>
	</parameter>
	<parameter name="pagoTransporteId" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select pag.id as pago_transporte_id,
pag.numero_comprobante,
pag.fecha_de_pago,
pag.total_pagable,
det.id as detalle_pago_transporte_id,
det.lote,
det.fecha_de_recepcion,
emp.id as empresa_id,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
det.nombre_chofer,
det.placa_automovil,
det.peso_bruto,
det.tipo_de_material,
det.costo_de_transporte,
dep.nombre_deposito,
dep.codigo_deposito,
dep.direccion as direccion_deposito
from liquidacion_demo.detalle_pago_transporte det
inner join liquidacion_demo.pago_transporte pag on pag.id=det.pago_transporte_id
inner join liquidacion_demo.recepcion rec on rec.id=det.recepcion_id
inner join liquidacion_demo.empresa emp on emp.id=rec.empresa_id
left join liquidacion_demo.deposito dep on dep.id=pag.deposito_id
where det.pago_transporte_id=$P{pagoTransporteId}]]>
	</queryString>
