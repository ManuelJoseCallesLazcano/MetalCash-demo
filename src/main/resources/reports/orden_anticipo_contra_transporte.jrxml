	</parameter>
	<queryString>
		<![CDATA[SELECT apt.id,
apt.numero_comprobante,
apt.gestion_minera,
apt.fecha,
apt.recepcion_de_complejo_id,
apt.nombre_cobrador,
apt.ci,
apt.solicitante,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
aut.placa,
aut.modelo,
aut.color,
apt.descripcion,
apt.importe,
apt.importe_literal,
apt.anulado,
apt.observaciones,
usu.nombre as usuario
FROM liquidacion_demo.anticipo_por_transporte apt
left join liquidacion_demo.empresa emp on emp.id=apt.empresa_id
left join liquidacion_demo.automovil aut on aut.id=apt.automovil_id
inner join liquidacion_demo.sec_user usu on usu.id=apt.usuario_id
where apt.id=$P{id}]]>
	</queryString>
