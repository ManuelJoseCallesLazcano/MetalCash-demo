	<parameter name="realPath" class="java.lang.String">
		<defaultValueExpression><![CDATA["/home/manuel/IdeaProjects/ALLOMIN/sistemaLiquidacionesAllomin/web-app/reports/images/"]]></defaultValueExpression>
	</parameter>
	<parameter name="anticipoId" class="java.lang.String">
		<defaultValueExpression><![CDATA[3]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT apt.id,
apt.numero_comprobante,
rec.codigo_lote,
apt.fecha,
apt.recepcion_de_complejo_id,
apt.nombre_cobrador,
apt.ci,
apt.solicitante,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
aut.placa,
aut.modelo,
apt.descripcion,
apt.importe,
apt.importe_literal,
apt.observaciones,
usu.nombre as nombre_usuario
FROM liquidacion_demo.anticipo_por_transporte apt
left join liquidacion_demo.empresa emp on emp.id=apt.empresa_id
left join liquidacion_demo.automovil aut on aut.id=apt.automovil_id
left join liquidacion_demo.recepcion rec on rec.id=apt.recepcion_de_complejo_id
inner join liquidacion_demo.sec_user usu on usu.id=apt.usuario_id
where apt.id=$P{anticipoId}]]>
	</queryString>
