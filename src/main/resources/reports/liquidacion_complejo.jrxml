	<queryString>
		<![CDATA[select li.id,
li.numero_liquidacion_complejo,
li.lote,
li.tipo_de_mineral,
li.nombre_empresa,
em.tipo_de_empresa,
em.nombre_de_empresa,
em.nit,
em.nim,
em.aplicar_bono_transporte,
em.municipio,
em.codigo_municipio,
li.nombre_cliente,
li.fecha_de_liquidacion,
li.fecha_de_recepcion,
li.cotizacion_diaria_de_zinc,
li.cotizacion_quincenal_de_zinc,
li.cotizacion_diaria_de_plomo,
li.cotizacion_quincenal_de_plomo,
li.cotizacion_diaria_de_plata,
li.cotizacion_quincenal_de_plata,
li.tipo_de_cambio_comercial,
li.tipo_de_cambio_oficial,
li.alicuota_de_zinc,
li.alicuota_de_plomo,
li.alicuota_de_plata,
li.peso_bruto,
re.cantidad_de_sacos,
li.kilos_netos_humedos,
li.porcentaje_merma_final,
li.porcentaje_humedad_final,
li.kilos_netos_secos,
li.porcentaje_zinc_final,
li.porcentaje_plomo_final,
li.porcentaje_plata_final,
li.kilos_finos_zinc,
li.kilos_finos_plomo,
li.kilos_finos_plata,
li.libras_finas_de_zinc,
li.libras_finas_de_plomo,
li.onzas_troy_de_plata,
li.valor_oficial_bruto_de_zinc,
li.valor_oficial_bruto_de_plomo,
li.valor_oficial_bruto_de_plata,
li.valor_oficial_bruto_de_zinc_en_bolivianos,
li.valor_oficial_bruto_de_plomo_en_bolivianos,
li.valor_oficial_bruto_de_plata_en_bolivianos,
li.valor_oficial_bruto,
li.valor_neto_mineral,
li.valor_neto_mineral_en_bolivianos,
li.modo_valoracion,
li.valor_por_tonelada,
li.valor_pagable_mineral,
li.bono_calidad,
li.bono_transporte,
li.bono_lealtad,
li.total_bonos,
li.valor_de_compra,
li.regalia_minera,
li.total_retenciones,
li.total_pagado,
li.total_anticipos_contra_entrega,
li.total_anticipos_contra_futura_entrega,
li.total_anticipos,
li.total_liquido_pagable,
li.total_liquido_pagable_literal,
li.bono_transporte_kilos_netos_secos_total,
li.total_liquido_pagable_final,
li.anulado,
ul.nombre as liquidador,
ur.nombre as receptor
from liquidacion_demo.liquidacion li
inner join liquidacion_demo.recepcion re on li.recepcion_de_complejo_id=re.id
inner join liquidacion_demo.empresa em on em.id=re.empresa_id
inner join liquidacion_demo.sec_user ul on li.usuario_id=ul.id
inner join liquidacion_demo.sec_user ur on re.usuario_id=ur.id
where li.id = $P{id}]]>
	</queryString>
