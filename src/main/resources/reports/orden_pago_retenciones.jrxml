	<parameter name="pagoRetencionesId" class="java.lang.String">
		<defaultValueExpression><![CDATA[8]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select pag.id,
pag.numero_comprobante,
pag.ci,
pag.nombre_cobrador,
pag.beneficiario,
pag.descripcion,
pag.fecha_de_pago,
pag.periodo,
pag.quincena,
pag.observaciones,
pag.total_pagable,
pag.total_pagable_literal,
tot.retencion,
tot.total,
usu.nombre,
dep.nombre_deposito,
dep.codigo_deposito,
dep.direccion as direccion_deposito,
emp.tipo_de_empresa,
emp.nombre_de_empresa
from liquidacion_demo.pago_de_retenciones pag
inner join liquidacion_demo.total_retencion_pagada tot on tot.pago_de_retenciones_id=pag.id
inner join liquidacion_demo.sec_user usu on pag.usuario_id=usu.id
left join liquidacion_demo.deposito dep on dep.id=pag.deposito_id
left join liquidacion_demo.empresa emp on emp.id=pag.empresa_id
where pag.id=$P{pagoRetencionesId}]]>
	</queryString>
