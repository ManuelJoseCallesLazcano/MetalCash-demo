	<queryString>
		<![CDATA[select acfe.fecha,
acfe.numero_amortizacion,
acfe.gestion_minera,
emp.tipo_de_empresa,
emp.nombre_de_empresa,
cli.nombre,
cli.ci,
acfe.importe,
acfe.importe_literal,
acfe.saldo_por_pagar,
acfe.concepto,
acfe.observaciones,
acfe.anulado,
usr.nombre as usuario
from liquidacion_demo.amortizacion acfe
inner join liquidacion_demo.cliente cli on acfe.cliente_id=cli.id
inner join liquidacion_demo.empresa emp on acfe.empresa_id=emp.id
inner join liquidacion_demo.sec_user usr on acfe.usuario_id=usr.id
where acfe.id=$P{id}]]>
	</queryString>
